# Environment Variables Template
# Copy this file to .env and fill in your values.
# DO NOT commit .env or raw keys to git!

VITE_FAL_KEY=your_fal_ai_key_here
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Paddle Billing (Client-side — safe for browser) ─────────────────────────
# Get from: Paddle Dashboard → Developer Tools → Authentication → Client-side tokens
VITE_PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxx

# Environment: "sandbox" for testing, "production" for live
VITE_PADDLE_ENV=sandbox

# Price IDs for each plan tier (from Paddle Dashboard → Catalog → Prices)
VITE_PADDLE_PRICE_BASIC=pri_xxxxxxxxxxxx
VITE_PADDLE_PRICE_PRO=pri_xxxxxxxxxxxx
VITE_PADDLE_PRICE_BUSINESS=pri_xxxxxxxxxxxx

# ── Paddle Billing (Server-side only — NEVER prefix with VITE_) ─────────────
# Get from: Paddle Dashboard → Developer Tools → Authentication → API Keys
PADDLE_API_KEY=your_paddle_api_key

# Webhook signing secret (verify webhook signatures)
PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxxxxxxxxxxx

# ── Supabase (Server-side only) ─────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Optional: Paddle customer portal URL for "Manage subscription" link ─────
VITE_BILLING_PORTAL_URL=
